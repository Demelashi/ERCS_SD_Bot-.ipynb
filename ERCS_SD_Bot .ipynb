def build_disaster_keyboard(lang):
    return ReplyKeyboardMarkup(
        [[f"{sym} {am if lang=='am' else en}"] for en, am, sym in DISASTER_TYPES],
        resize_keyboard=True
    )

def build_disease_keyboard(lang):
    return ReplyKeyboardMarkup(
        [[f"{sym} {am if lang=='am' else en}"] for en, am, sym in DISEASE_TYPES],
        resize_keyboard=True
    )

def build_woreda_keyboard():
    return ReplyKeyboardMarkup([[w] for w in WOREDA_OPTIONS], resize_keyboard=True)

def build_main_menu_keyboard(lang):
    texts = get_texts(lang)
    return ReplyKeyboardMarkup([
        [texts['emergency_report']],
        [texts['feedback']],
        [texts['language']]
    ], resize_keyboard=True)

# ========== HANDLERS ==========
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if user_id not in user_data:
        user_data[user_id] = {'lang': 'en'}
    await show_main_menu(update, user_id)

async def contacts(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    lang = user_data.get(user_id, {}).get('lang', 'en')
    await update.message.reply_text(get_texts(lang)['contacts'])

async def show_main_menu(update, user_id):
    lang = user_data[user_id]['lang']
    texts = get_texts(lang)
    await update.message.reply_text(
        texts['main_menu'],
        reply_markup=build_main_menu_keyboard(lang)
    )

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    msg = update.message.text

    if user_id not in user_data:
        await start(update, context)
        return

    lang = user_data[user_id]['lang']
    texts = get_texts(lang)

    if msg == texts['language']:
        user_data[user_id]['lang'] = 'am' if lang == 'en' else 'en'
        await show_main_menu(update, user_id)
        return
    if msg == texts['emergency_report']:
        await start_emergency_report(update, user_id, lang)
        return
    if msg == texts['feedback']:
        await start_feedback(update, user_id, lang)
        return

    step = user_data[user_id].get('step')
    
    # Dispatch steps
    if step == 'disaster_type':
        await process_disaster_type(update, user_id, lang, msg)
    elif step == 'disease_type':
        await process_disease_type(update, user_id, lang, msg)
    elif step == 'woreda':
        await request_kebele(update, user_id, lang, msg)
    elif step == 'kebele':
        await request_affected(update, user_id, lang, msg)
    elif step == 'affected':
        await request_deaths(update, user_id, lang, msg)
    elif step == 'dead':
        await start_general_faq(update, user_id)
    elif step == 'faq_question':
        await process_faq_question(update, user_id, msg)
    elif step == 'suggestions':
        await complete_report(update, user_id, lang, msg)

# ========== REPORT FLOW ==========
async def start_emergency_report(update, user_id, lang):
    user_data[user_id]['step'] = 'disaster_type'
    user_data[user_id]['form'] = {}
    texts = get_texts(lang)
    await update.message.reply_text(
        texts['select_disaster'],
        reply_markup=build_disaster_keyboard(lang)
    )

async def process_disaster_type(update, user_id, lang, msg):
    symbol = msg.split()[0]
    for en, am, sym in DISASTER_TYPES:
        if sym == symbol:
            user_data[user_id]['form']['Disaster Type'] = en
            break
    if user_data[user_id]['form']['Disaster Type'] == "Disease":
        user_data[user_id]['step'] = 'disease_type'
        texts = get_texts(lang)
        await update.message.reply_text(
            texts['select_disease'],
            reply_markup=build_disease_keyboard(lang)
        )
    else:
        user_data[user_id]['form']['Disease'] = 'N/A'
        await request_woreda(update, user_id, lang)

async def process_disease_type(update, user_id, lang, msg):
    symbol = msg.split()[0]
    for en, am, sym in DISEASE_TYPES:
        if sym == symbol:
            user_data[user_id]['form']['Disease'] = en
            break
    await request_woreda(update, user_id, lang)

async def request_woreda(update, user_id, lang):
    user_data[user_id]['step'] = 'woreda'
    texts = get_texts(lang)
    await update.message.reply_text(
        texts['select_woreda'],
        reply_markup=build_woreda_keyboard()
    )

async def request_kebele(update, user_id, lang, msg):
    user_data[user_id]['form']['Woreda'] = msg
    user_data[user_id]['step'] = 'kebele'
    texts = get_texts(lang)
    await update.message.reply_text(texts['enter_kebele'])

async def request_affected(update, user_id, lang, msg):
    user_data[user_id]['form']['Kebele'] = msg
    user_data[user_id]['step'] = 'affected'
    texts = get_texts(lang)
    await update.message.reply_text(texts['enter_affected'])

async def request_deaths(update, user_id, lang, msg):
    if not msg.isdigit():
        await update.message.reply_text("❌ Please enter a valid number.")
        return
    user_data[user_id]['form']['Affected'] = msg
    user_data[user_id]['step'] = 'dead'
    texts = get_texts(lang)
    await update.message.reply_text(texts['enter_deaths'])

# ========== GENERAL FAQ ==========
async def start_general_faq(update, user_id):
    """Start asking the general disease FAQ in user's language."""
    lang = user_data[user_id].get('lang', 'en')
    faq_list = GENERAL_DISEASE_FAQ_AM if lang == 'am' else GENERAL_DISEASE_FAQ_EN
    user_data[user_id]['faq_index'] = 0
    user_data[user_id]['faq_answers'] = {}
    user_data[user_id]['step'] = 'faq_question'
    user_data[user_id]['current_faq'] = faq_list
    await update.message.reply_text(faq_list[0])

async def process_faq_question(update, user_id, msg):
    idx = user_data[user_id]['faq_index']
    user_data[user_id]['faq_answers'][f"FAQ_{idx+1}"] = msg
    idx += 1
    faq_list = user_data[user_id]['current_faq']
    if idx < len(faq_list):
        user_data[user_id]['faq_index'] = idx
        await update.message.reply_text(faq_list[idx])
    else:
        user_data[user_id]['step'] = 'suggestions'
        lang = user_data[user_id].get('lang', 'en')
        texts = get_texts(lang)
        await update.message.reply_text(texts['ask_suggestions'])

# ========== COMPLETE REPORT ==========
async def complete_report(update, user_id, lang, msg):
    user_data[user_id]['form']['Suggestions'] = msg
    user_data[user_id]['form']['Timestamp'] = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    # Merge FAQ answers
    user_data[user_id]['form'].update(user_data[user_id].get('faq_answers', {}))
    all_reports.append(user_data[user_id]['form'].copy())
    generate_weekly_report()
    await update.message.reply_text(get_texts(lang)['submit_success'])
    await show_main_menu(update, user_id)

# ========== FEEDBACK ==========
async def start_feedback(update, user_id, lang):
    user_data[user_id]['step'] = 'suggestions'
    texts = get_texts(lang)
    await update.message.reply_text(texts['feedback_prompt'])

# ========== BOT LAUNCH ==========
async def run_bot():
    app = ApplicationBuilder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("contacts", contacts))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    print("✅ ERCS Bot is running. Press Ctrl+C to stop.")
    await app.initialize()
    await app.start()
    await app.updater.start_polling()

await run_bot()
